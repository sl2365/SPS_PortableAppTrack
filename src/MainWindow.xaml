<Window x:Class="ElementalTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Elemental Tracker" Width="1200" Height="800"
        MinWidth="1100" MinHeight="500"
        WindowStartupLocation="Manual">

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Track" Click="MenuNewTrack_Click" />
                <MenuItem Header="_Open Category" Click="OpenCategoryFolder_Click" />
                <Separator />
                <MenuItem Header="_Save" Click="Save_Click" />
                <MenuItem Header="Save _As..." Click="SaveTrackAs_Click" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <!-- REMOVE:  IsEnabled="False" Opacity="0.4" TO ENABLE ITEMS -->
            <MenuItem Header="_View">
                <MenuItem Header="Settings" x:Name="menuViewSettings" />
                <MenuItem Header="Theme..." x:Name="menuViewTheme" />
            </MenuItem>
			<MenuItem Header="_Tools">
			    <MenuItem Header="Open new SPSBuilder" x:Name="menuOpenSpsBuilder" Click="OpenNewSpsBuilder_Click" Visibility="Collapsed" />
			    <MenuItem Header="Select Suites..." x:Name="menuSelectSuites" Click="SelectSuites_Click" Visibility="Collapsed" />
			    <Separator x:Name="menuToolsSpsSeparator" Visibility="Collapsed" />
			    <MenuItem Header="Install/Update uBlock Origin" Click="InstallUBlock_Click" />
			    <MenuItem Header="List Extensions" Click="ListExtensions_Click" />
			</MenuItem>
            <MenuItem Header="_Config" IsEnabled="False" Opacity="0.4">
            </MenuItem>
        </Menu>

		<!-- Toolbar - adjust Padding and Margin to suit -->
		<ToolBarTray x:Name="toolBarTray" DockPanel.Dock="Top">
		    <ToolBar x:Name="mainToolBar" Band="0" BandIndex="0">
		    	<Button x:Name="btnAddCategory" Content="&#xECC8;" Click="NewCategory_Click"
				        FontFamily="Segoe Fluent Icons" FontSize="17"
				        Padding="7,4" Margin="2,2,2,2" ToolTip="New Category" />
				<Button x:Name="btnRemoveCategory" Content="&#xECC9;" Click="DeleteCategory_Click"
				        FontFamily="Segoe Fluent Icons" FontSize="17"
				        Padding="7,4" Margin="2,2,2,2" ToolTip="Delete Category" />
				<Button x:Name="btnOpenFolder" Content="&#xE838;" Click="OpenCategoryFolder_Click"
				        FontFamily="Segoe Fluent Icons" FontSize="17"
				        Padding="7,4" Margin="2,2,2,2" ToolTip="Open category folder" />
				<Button x:Name="btnRefreshCategories" Content="&#xE72C;" Click="RefreshCategories_Click"
				        FontFamily="Segoe Fluent Icons" FontSize="17"
				        Padding="7,4" Margin="2,2,2,2" ToolTip="Refresh lists" />
				<Separator />
		        <Button x:Name="btnSave" Content="&#xE74E;" Click="Save_Click"
		                FontFamily="Segoe Fluent Icons" FontSize="17"
		                Padding="7,4" Margin="2,2,2,2" ToolTip="Save track file"
		                IsEnabled="False" Opacity="0.4" />
		        <Button x:Name="btnSaveAs" Content="&#xE792;" Click="SaveTrackAs_Click"
		                FontFamily="Segoe Fluent Icons" FontSize="17"
		                Padding="7,4" Margin="2,2,2,2" ToolTip="Save track as..."
		                IsEnabled="False" Opacity="0.4" />
		        <Button x:Name="btnSaveAll" Content="&#xE78C;" Click="SaveAll_Click"
		                FontFamily="Segoe Fluent Icons" FontSize="17"
		                Padding="7,4" Margin="2,2,2,2" ToolTip="Update versions and save all tracks in category"
		                IsEnabled="False" Opacity="0.4" />
		        <Separator />
		        <Button x:Name="btnToggleLayout" Content="&#xeca5;" Click="ToggleLayout_Click"
		                FontFamily="Segoe Fluent Icons" FontSize="17"
		                Padding="7,4" Margin="2,2,2,2" ToolTip="Switch to Horizontal Layout" />
		        <Separator />
		        <Button x:Name="btnCheckSelected" Content="&#xe930;" Click="CheckSelected_Click"
		                FontFamily="Segoe Fluent Icons" FontSize="17"
		                Padding="7,4" Margin="2,2,2,2" ToolTip="Check selected tracks in current category" />
		        <Button x:Name="btnCheckAll" Content="&#xec61;" Click="CheckAll_Click"
		                FontFamily="Segoe Fluent Icons" FontSize="17"
		                Padding="7,4" Margin="2,2,2,2" ToolTip="Check all tracks in current category" />
		        <Separator />
                <Button x:Name="btnToolbarReBuild" Content="&#xE777;" Click="ReBuild_Click"
                        FontFamily="Segoe Fluent Icons" FontSize="17"
                        Padding="7,4" Margin="2,2,2,2"
                        ToolTip="Scan SyMenu SPS cache and rebuild category from SPS data" />
		        <Button x:Name="btnAbout" Content="&#xe9ce;" Click="About_Click"
		                FontFamily="Segoe Fluent Icons" FontSize="17"
		                Padding="7,4" Margin="2,2,2,2" ToolTip="Help" />
		    </ToolBar>
		</ToolBarTray>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True" />
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem DockPanel.Dock="Left" Margin="5,0,0,0">
                <ProgressBar x:Name="statusProgress" Width="150" Height="16"
                             Minimum="0" Maximum="100" Value="0" />
            </StatusBarItem>

            <StatusBarItem DockPanel.Dock="Right" Margin="0,0,5,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xF136;" FontFamily="Segoe Fluent Icons" FontSize="12"
                               Foreground="#00B400" VerticalAlignment="Center" Margin="0,0,2,0" />
                    <TextBlock Text="Unchanged" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="&#xF136;" FontFamily="Segoe Fluent Icons" FontSize="12"
                               Foreground="#FFB400" VerticalAlignment="Center" Margin="0,0,2,0" />
                    <TextBlock Text="Changed" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="&#xF136;" FontFamily="Segoe Fluent Icons" FontSize="12"
                               Foreground="#DC2828" VerticalAlignment="Center" Margin="0,0,2,0" />
                    <TextBlock Text="Error" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="&#xF136;" FontFamily="Segoe Fluent Icons" FontSize="12"
                               Foreground="#2878DC" VerticalAlignment="Center" Margin="0,0,2,0" />
                    <TextBlock Text="New" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="&#xF136;" FontFamily="Segoe Fluent Icons" FontSize="12"
                               Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,2,0" />
                    <TextBlock Text="Unchecked" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem>
                <TextBlock x:Name="statusFile" Text="No file loaded" TextTrimming="CharacterEllipsis" />
            </StatusBarItem>
        </StatusBar>

        <!-- Main content area -->
        <Grid x:Name="mainContent">

            <!-- LAYOUT: Vertical split (default) -->
            <Grid x:Name="layoutVertical">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="450" MinWidth="300" MaxWidth="700" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" MinWidth="300" />
                </Grid.ColumnDefinitions>

                <!-- Left side: top has Cat+List, bottom has Track Settings -->
                <Grid Grid.Column="0">
	                <Grid.RowDefinitions>
	                    <RowDefinition Height="*" MinHeight="150" />
	                    <RowDefinition Height="5" />
	                    <RowDefinition Height="*" MinHeight="250" />
	                </Grid.RowDefinitions>

                    <!-- Top: Categories + List side by side -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" MinWidth="120" MaxWidth="300" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" MinWidth="150" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="catHostV" Grid.Column="0" MinWidth="120" />

                        <GridSplitter Grid.Column="1" Width="5"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="LightGray" Cursor="SizeWE" />

                        <Border x:Name="listHostV" Grid.Column="2" MinWidth="150" />
                    </Grid>

                    <!-- Horizontal splitter -->
                    <GridSplitter x:Name="trackSettingsSplitterV" Grid.Row="1" Height="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="LightGray" Cursor="SizeNS" />

                    <!-- Bottom: Track Settings spanning full width -->
                    <Border x:Name="trackSettingsHostV" Grid.Row="2" MinHeight="150" />
                </Grid>

                <!-- Vertical splitter -->
                <GridSplitter Grid.Column="1" Width="5"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="LightGray" Cursor="SizeWE" />

                <!-- Right: Tabs full height -->
                <Border x:Name="tabsHostV" Grid.Column="2" MinWidth="300" />
            </Grid>

            <!-- LAYOUT: Horizontal split - 2x2 grid -->
            <Grid x:Name="layoutHorizontal" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="150" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="*" MinHeight="250" />
                </Grid.RowDefinitions>

                <!-- Top row: Categories + Track List -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" MinWidth="120" MaxWidth="400" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" MinWidth="200" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="catHostH" Grid.Column="0" />
                    <GridSplitter Grid.Column="1" Width="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="LightGray" Cursor="SizeWE" />
                    <Border x:Name="listHostH" Grid.Column="2" />
                </Grid>

                <!-- Horizontal Splitter -->
                <GridSplitter Grid.Row="1" Height="5"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="LightGray" Cursor="SizeNS" />

                <!-- Bottom row: Track Settings + Tabs -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="250" MaxWidth="600" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" MinWidth="250" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="trackSettingsHostH" Grid.Column="0" />
                    <GridSplitter x:Name="trackSettingsSplitterH" Grid.Column="1" Width="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="LightGray" Cursor="SizeWE" />
                    <Border x:Name="tabsHostH" Grid.Column="2" />

                </Grid>
            </Grid>

        </Grid>
    </DockPanel>

    <!-- ========================================== -->
    <!-- SHARED CONTROLS - defined once, moved between layouts -->
    <!-- ========================================== -->
    <Window.Resources>
        <!-- Empty - resources go here later for theming -->
    </Window.Resources>

</Window>